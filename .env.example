# Uretimde zorunlu (min 16 karakter)
AUTH_SECRET=

# PostgreSQL (Docker: docker compose up -d)
# Gelistirmede bos birakilirsa docker-compose ile ayni varsayilan kullanilir (konsola uyari yazilir).
# Uretimde mutlaka ayarlayin.
DATABASE_URL=postgresql://oyunticaret:oyunticaret_dev@localhost:5432/oyunticaret

# Opsiyonel: pg havuz boyutu
# PG_POOL_MAX=15

# Kayit sonrasi baslangic bakiyesi (TL); gercek urunde genelde 0
MOCK_INITIAL_BALANCE_TL=0

# Simule bakiye yukleme limitleri (TL)
# MOCK_MIN_TOPUP_TL=50
# MOCK_MAX_TOPUP_TL=100000

# 1 yaparsaniz /hesabim sayfasinda ekstra demo +1000 TL butonu (gelistirme)
MOCK_BAKIYE_DEMOSU=

# Veri tohumlama (Docker Postgres acikken): npm run seed:users && npm run seed:listings
# veya: npm run seed

# Virgulle ayrilmis yonetici e-postalari ( /admin/moderasyon )
# ADMIN_EMAILS=you@example.com
ADMIN_EMAILS=

# Admin seed script ayarlari (opsiyonel)
# npm run seed:admin
# npm run db:reset
# ADMIN_SEED_EMAIL=admin@oyunticaret.local
# ADMIN_SEED_PASSWORD=Admin!123456
# ADMIN_SEED_DISPLAY_NAME=Admin
# ADMIN_SEED_INITIAL_BALANCE_TL=0
